{
  "name": "Modern Free",
  "description": "Clean, professional modern resume template. Perfect for all industries.",
  "type": "resume",
  "tier": "free",
  "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset='UTF-8'>\n<title>{{fullName}} Resume</title>\n<style>\nbody { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 20px; line-height: 1.6; color: #333; }\n.header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 30px; text-align: center; border-radius: 10px 10px 0 0; }\n.name { font-size: 2.5em; margin: 0; font-weight: bold; }\n.contact { margin: 10px 0; font-size: 1.1em; opacity: 0.9; }\n.section { margin: 30px 0; padding-left: 20px; border-left: 4px solid #667eea; }\n.section h2 { color: #667eea; font-size: 1.5em; margin-bottom: 15px; }\n.skills { display: flex; flex-wrap: wrap; gap: 10px; }\n.skill { background: #667eea; color: white; padding: 5px 12px; border-radius: 20px; font-size: 0.9em; }\n</style>\n</head>\n<body>\n<div class='header'>\n<h1 class='name'>{{fullName}}</h1>\n<p class='contact'>{{email}} | {{phone}} | {{location}}</p>\n</div>\n<div class='section'>\n<h2>Professional Summary</h2>\n<p>{{summary}}</p>\n</div>\n<div class='section'>\n<h2>Skills</h2>\n<div class='skills'>\n{{#each skills}}<span class='skill'>{{this}}</span>{{/each}}\n</div>\n</div>\n<div class='section'>\n<h2>Experience</h2>\n{{#each experience}}<h3>{{title}} - {{company}} ({{dates}})</h3>\n<p>{{description}}</p>{{/each}}\n</div>\n<div class='section'>\n<h2>Education</h2>\n{{#each education}}<h3>{{degree}} - {{school}} ({{dates}})</h3>{{/each}}\n</div>\n</body>\n</html>",
  "css": "",
  "js": "",
  "category": "modern",
  "previewImage": "/templates/previews/resume-modern.png"
}
