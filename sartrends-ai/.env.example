# SAR Trends AI - Environment Variables
# Copy this file to .env and fill in your values

# ========================
# SERVER CONFIGURATION
# ========================
PORT=5000
NODE_ENV=development

# ========================
# DATABASE
# ========================
MONGODB_URI=mongodb://localhost:27017/sartrends-ai
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sartrends-ai

# ========================
# JWT SECRET
# ========================
# Generate a strong random string for production
JWT_SECRET=sartrends-secret-key-change-in-production-2024

# ========================
# AI PROVIDERS
# ========================

# OpenAI Configuration (Primary - Recommended: gpt-4o-mini for low cost)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Groq AI Configuration (Fallback #1 - Free tier available)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=mixtral-8x7b-32768

# Together AI Configuration (Fallback #2)
TOGETHER_API_KEY=your-together-ai-api-key-here
TOGETHER_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# ========================
# PAYMENT CONFIGURATION
# ========================

# Easypaisa (for Pakistan)
EASYPAISA_MERCHANT_ID=your-merchant-id
EASYPAISA_SECRET_KEY=your-secret-key

# Meezan Bank
MEEZAN_ACCOUNT_NUMBER=your-account-number
MEEZAN_IBAN=your-iban

# ========================
# WHATSAPP NOTIFICATIONS
# ========================
WHATSAPP_NUMBER=923454837460

# ========================
# ADMIN CONFIGURATION
# ========================
ADMIN_EMAIL=admin@sartrends.store
ADMIN_PASSWORD=admin123

# ========================
# FRONTEND URL (for CORS)
# ========================
FRONTEND_URL=http://localhost:3000

